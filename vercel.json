{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.{png,jpg}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/api/(.*)", "dest": "api/index.js" }
  ]
}
